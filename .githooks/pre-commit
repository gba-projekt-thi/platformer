#!/bin/bash
# Pre-commit hook for code formatting and linting
# Install: cp .githooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
CLANG_FORMAT=$(which clang-format || echo "clang-format")
CLANG_TIDY=$(which clang-tidy || echo "clang-tidy")
COMPILE_DB="/workspace/compile_commands.json"

# Get list of staged C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|hpp|cc)$' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Check if compile_commands.json exists
if [ ! -f "$COMPILE_DB" ]; then
    echo -e "${YELLOW}⚠ compile_commands.json not found. Skipping clang-tidy.${NC}"
    echo -e "${YELLOW}  Run: cd src/sprites && bear -- make && cp compile_commands.json /workspace/${NC}"
    SKIP_TIDY=true
fi

# Run clang-format
echo -e "${YELLOW}Formatting code...${NC}"
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        $CLANG_FORMAT -i "$file"
        git add "$file"
    fi
done
echo -e "${GREEN}✓ Formatting complete${NC}"

# Run clang-tidy (if compile_commands.json exists)
if [ "$SKIP_TIDY" != "true" ]; then
    echo -e "${YELLOW}Running clang-tidy checks...${NC}"
    
    TIDY_FAILED=false
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Only check user source files, not build artifacts
            if [[ "$file" == "src/"* ]]; then
                if ! $CLANG_TIDY -p="$(dirname $COMPILE_DB)" "$file" --quiet 2>&1 | grep -q "error:"; then
                    echo -e "${GREEN}✓ $file${NC}"
                else
                    echo -e "${RED}✗ $file${NC}"
                    TIDY_FAILED=true
                fi
            fi
        fi
    done
    
    if [ "$TIDY_FAILED" = true ]; then
        echo -e "${RED}✗ Clang-tidy found issues${NC}"
        echo -e "${YELLOW}  Review warnings and fix issues before committing${NC}"
        exit 1
    fi
fi

echo -e "${GREEN}✓ All checks passed${NC}"
exit 0
