{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-game",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "clean-game",
            "type": "shell",
            "command": "make clean",
            "problemMatcher": []
        },
        {
            "label": "run-rom-host",
            "type": "shell",
            "command": "mgba-qt",
            "args": [
                "${workspaceFolder}/game/foo.gba"
            ],
            "problemMatcher": []
        },
        {
            "label": "test-rom",
            "type": "shell",
            "command": "./test-rom.sh",
            "args": [
                "game/foo.gba"
            ],
            "problemMatcher": []
        }
    ]
}
